const http = require('http');
const server = http.createServer((req, res) => {
res.writeHead(200); // This means "Everything is
OK!"
res.end("Hello world!"); // Send this message
back
});
const HOST = '0.0.0.0'; // Let anyone visit
const PORT = 80; // Standard website port
server.listen(PORT, HOST, () => {
console.log("Server is running!");
});